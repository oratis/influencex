# PostgreSQL (optional — omit to use local SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/influencex

# Network proxy (optional, for local dev behind restrictive networks)
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# Resend Email API
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=contact@yourdomain.com
RESEND_REPLY_TO=replies@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_your_signing_secret

# Hunter.io - domain email search
HUNTER_API_KEY=your_hunter_api_key

# Google Analytics 4 Data API
GA4_PROPERTY_ID=your_ga4_property_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Feishu (Lark) Open API
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Feishu Spreadsheet IDs (optional, defaults are provided)
# FEISHU_CONTENT_SHEET_TOKEN=your_content_sheet_token
# FEISHU_CONTENT_SHEET_ID=your_content_sheet_id
# FEISHU_REG_SHEET_TOKEN=your_reg_sheet_token
# FEISHU_REG_SHEET_ID=your_reg_sheet_id

# Admin setup (first run only)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_on_first_run
ADMIN_NAME=Admin

# CORS (comma-separated, only enforced in production)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Outbound notifications (configure whichever you want; leave blank to disable)
# NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# NOTIFY_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/...
# NOTIFY_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# NOTIFY_GENERIC_WEBHOOK_URL=https://your-webhook-endpoint.example/ingest

# Scheduler (background email sending)
# SCHEDULER_ENABLED=true
# SCHEDULER_TICK_MS=300000        # 5 min
# FOLLOW_UP_AFTER_DAYS=4
# MAX_FOLLOW_UPS=1

# YouTube API daily quota (default 10000, set lower if you have a reduced quota)
# YOUTUBE_QUOTA_DAILY=10000

# Apify (optional) - enables real Instagram / TikTok scraping
# Sign up at https://apify.com, copy your personal API token
# APIFY_TOKEN=apify_api_...

# Email template defaults
# SENDER_NAME=Your Name
# PRODUCT_NAME=Your Product
